{
  "name": "MentorshipRequest",
  "type": "object",
  "properties": {
    "from_email": {
      "type": "string"
    },
    "to_email": {
      "type": "string"
    },
    "from_name": {
      "type": "string"
    },
    "to_name": {
      "type": "string"
    },
    "topic": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "accepted",
        "rejected",
        "completed"
      ],
      "default": "pending"
    },
    "meeting_link": {
      "type": "string"
    },
    "scheduled_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "from_email",
    "to_email",
    "topic"
  ]
}