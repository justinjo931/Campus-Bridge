{
  "name": "ForumPost",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Post title"
    },
    "content": {
      "type": "string",
      "description": "Post content in markdown"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Topic tags"
    },
    "is_anonymous": {
      "type": "boolean",
      "default": false
    },
    "upvotes": {
      "type": "number",
      "default": 0
    },
    "upvoted_by": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Emails of users who upvoted"
    },
    "reply_count": {
      "type": "number",
      "default": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "closed",
        "flagged",
        "removed"
      ],
      "default": "active"
    },
    "author_name": {
      "type": "string"
    },
    "author_role": {
      "type": "string"
    },
    "author_department": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "content"
  ]
}